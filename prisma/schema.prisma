// prisma/schema.prisma
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String      @id @default(cuid())
  fullName    String?
  gender      genderType  @default(MALE)
  type        userType    @default(MEMBER)
  age         Int
  
  christianName String?   // የክርስትና ስም
  registerDate  String?   // የምዝገባ ቀን

  // If User is Admin or Superadmin
  email       String?     @unique

  // If User is Member
  memberType  memberType? @default(REGULAR_MEMBER)

  // Relations
  attendances      Attendance[]      @relation("MemberAttendances")
  markedAttendances Attendance[]     @relation("MarkedByAdmin")
  permissions      Permission[]      @relation("MemberPermissions")
  reviewedPermissions Permission[]   @relation("ReviewedByAdmin")
  createdEvents    Event[]           @relation("EventCreatedBy")

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Ethiopian calendar fields for display
  ethiopianCreatedAt String?
}

enum userType {
  ADMIN
  MEMBER
  SUPERADMIN
}

enum genderType {
  MALE
  FEMALE
}

enum memberType {
  COURSE_STUDENT
  REGULAR_MEMBER
  YOUTH_STUDENT
}

// -------------------------
// EVENTS
// -------------------------

enum eventType {
  EVENT
  CHORE
  SUNDAY
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  location    String?

  // Ethiopian calendar fields
  ethiopianYear  Int?
  ethiopianMonth Int?
  ethiopianDay   Int?

  // Event type to distinguish real events from attendance tracking
  eventType   eventType @default(EVENT)

  // NEW: Mark if this is a recurring yearly event
  isRecurring   Boolean @default(false)
  // NEW: The original Ethiopian date (month and day only) for recurring events
  recurringMonth Int?   // 1-13
  recurringDay   Int?   // 1-30

  // Optional eligibility gate for this event
  eligibilityRuleId String?
  eligibilityRule   EligibilityRule? @relation(fields: [eligibilityRuleId], references: [id])

  // Which member types this event applies to (e.g. only YOUTH_STUDENT)
  targetMemberTypes memberType[]

  createdById String
  createdBy   User     @relation("EventCreatedBy", fields: [createdById], references: [id])

  attendances Attendance[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([ethiopianYear, ethiopianMonth])
  @@index([isRecurring])
}

// -------------------------
// ATTENDANCE
// -------------------------

model AttendanceType {
  id        String   @id @default(cuid())
  name      String   @unique   // e.g. "Attended", "Permission", "Absent", "Late"
  value     Float             // 1, 0.5, 0, or any custom weight
  isDefault Boolean  @default(false)

  attendances Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id     String @id @default(cuid())

  memberId String
  member   User   @relation("MemberAttendances", fields: [memberId], references: [id])

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  attendanceTypeId String
  attendanceType   AttendanceType @relation(fields: [attendanceTypeId], references: [id])

  // Linked if the attendance status is backed by an approved permission
  permissionId String?
  permission   Permission? @relation(fields: [permissionId], references: [id])

  markedById String
  markedBy   User   @relation("MarkedByAdmin", fields: [markedById], references: [id])

  note      String?
  
  // Track if this attendance was counted for eligibility
  countedForEligibility Boolean? @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, eventId])
  @@index([eventId])
  @@index([memberId])
}

// -------------------------
// PERMISSIONS
// -------------------------

enum permissionTypeCategory {
  DURATION_BASED  // Excused for X months/years
  DAY_BASED       // Excused on specific days (e.g., 1st, 21st) or Sundays
}

model PermissionType {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "Medical", "Travel", "Work", "Family"
  description String?
  category    permissionTypeCategory @default(DURATION_BASED)

  // For DURATION_BASED type
  durationMonths Int?   // Number of months the permission is valid
  durationYears  Int?   // Number of years the permission is valid
  appliesToChore Boolean @default(false)  // Applies to chore attendance
  appliesToSunday Boolean @default(false) // Applies to Sunday attendance

  // For DAY_BASED type
  specificDays Int[]  // Days of month (e.g., [1, 21])
  appliesToSundays Boolean @default(false) // Excused on all Sundays

  permissions Permission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum permissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Permission {
  id     String @id @default(cuid())

  memberId String
  member   User   @relation("MemberPermissions", fields: [memberId], references: [id])

  permissionTypeId String
  permissionType   PermissionType @relation(fields: [permissionTypeId], references: [id])

  reason String?
  status permissionStatus @default(PENDING)

  reviewedById String?
  reviewedBy   User?   @relation("ReviewedByAdmin", fields: [reviewedById], references: [id])

  attendances Attendance[]

  // Ethiopian calendar fields for the permission start date
  ethiopianStartDate String?
  ethiopianEndDate String?   // For duration-based permissions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -------------------------
// ELIGIBILITY
// -------------------------

model EligibilityRule {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  
  // Relations
  criteria           EligibilityCriteria[]
  events             Event[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model EligibilityCriteria {
  id                String   @id @default(cuid())
  eligibilityRuleId String
  eligibilityRule   EligibilityRule @relation(fields: [eligibilityRuleId], references: [id], onDelete: Cascade)
  
  // The type of event to count (chore, sunday, or specific event type)
  eventType         String   // "chore", "sunday", "total" for total attendances
  minAttendances    Int      // minimum number of attendances required
  lookbackMonths    Int      // number of months to look back from the event date
  
  // For total attendance option, we don't need eventType filter
  isTotalAttendance Boolean @default(false) // If true, counts all attendances regardless of type
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}